# ════════════════════════════════════════════
#   MANGA OCR BOT — Environment Variables
# ════════════════════════════════════════════

# ── Discord ─────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Anthropic (Claude Vision OCR) ────────────
# Get your key from: https://console.anthropic.com/
# Required for the ✨ Claude Vision engine (best accuracy on decorative fonts)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Google Drive ─────────────────────────────
# Option 1: JSON string (recommended for Railway)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Option 2: File path (for local development)
# GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Drive folder ID where files will be saved
# Get this from the folder URL: drive.google.com/drive/folders/THIS_PART
GDRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ── Optional Settings ────────────────────────
# Default OCR engine: tesseract | easyocr | manga_ocr
DEFAULT_ENGINE=easyocr

# Max ZIP file size in MB
MAX_ZIP_SIZE_MB=50

# Discord webhook URL for error/event logging (optional)
WEBHOOK_LOG_URL=https://discord.com/api/webhooks/your_webhook_here

# DeepL API key for higher-quality translation (optional, falls back to Google Translate)
DEEPL_API_KEY=your_deepl_key_here

# HTTP health check port for Railway (default: 8080)
PORT=8080

# Google Drive service account credentials JSON file path
GOOGLE_CREDENTIALS_FILE=credentials.json
